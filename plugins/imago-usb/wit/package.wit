package imago:usb@0.2.0;

/// Shared USB types used by provider, device, and interface APIs.
@since(version = 0.1.0)
interface types {
    /// Error codes returned by USB operations.
    @since(version = 0.1.0)
    variant usb-error {
        /// The requested path or operation is denied by policy.
        not-allowed,
        /// The operation timed out.
        timeout,
        /// The USB device disconnected.
        disconnected,
        /// The resource is busy.
        busy,
        /// The caller supplied an invalid argument.
        invalid-argument,
        /// The transfer failed due to device or bus faults.
        transfer-fault,
        /// The operation is unsupported on the current runtime backend.
        operation-not-supported,
        /// Any other implementation-defined error with detail text.
        other(string),
    }

    /// USB control transfer type.
    @since(version = 0.1.0)
    enum control-type {
        /// Standard USB request.
        standard,
        /// Class-specific request.
        class,
        /// Vendor-specific request.
        vendor,
    }

    /// USB control transfer recipient.
    @since(version = 0.1.0)
    enum recipient {
        /// Recipient is the entire device.
        device,
        /// Recipient is an interface.
        interface-target,
        /// Recipient is an endpoint.
        endpoint,
        /// Recipient is another implementation-defined target.
        other,
    }

    /// Runtime-enforced USB limits.
    @since(version = 0.1.0)
    record limits {
        /// Maximum payload bytes accepted by a single transfer request.
        max-transfer-bytes: u32,
        /// Maximum transfer timeout in milliseconds.
        max-timeout-ms: u32,
        /// Maximum number of allowlisted device paths.
        max-paths: u32,
        /// Fixed chunk size in bytes used by bulk ring readers.
        bulk-ring-chunk-bytes: u32,
        /// Number of chunks retained in each bulk ring reader.
        bulk-ring-slots: u32,
        /// Maximum bytes retained in each bulk ring reader.
        bulk-ring-max-bytes: u32,
    }

    /// Statistics for one bulk ring reader.
    @since(version = 0.2.0)
    record bulk-read-stats {
        /// Total dropped chunks caused by ring overflow.
        dropped-chunks: u64,
        /// Total dropped bytes caused by ring overflow.
        dropped-bytes: u64,
        /// Current buffered chunk count.
        buffered-chunks: u32,
        /// Current buffered byte count.
        buffered-bytes: u64,
    }

    /// Common setup fields for USB control transfers.
    @since(version = 0.1.0)
    record control-setup {
        /// Control transfer request type.
        control-type: control-type,
        /// Recipient targeted by this request.
        recipient: recipient,
        /// Raw `bRequest` field value.
        request: u8,
        /// Raw `wValue` field value.
        value: u16,
        /// Raw `wIndex` field value.
        index: u16,
    }

    /// Three-part version used in USB descriptors.
    @since(version = 0.1.0)
    record version {
        /// Major version component.
        major: u8,
        /// Minor version component.
        minor: u8,
        /// Subminor version component.
        subminor: u8,
    }

    /// Endpoint transfer direction.
    @since(version = 0.1.0)
    enum direction {
        /// Device-to-host endpoint.
        in,
        /// Host-to-device endpoint.
        out,
    }

    /// Isochronous usage type.
    @since(version = 0.1.0)
    enum usage-type {
        /// Data endpoint.
        data,
        /// Feedback endpoint.
        feedback,
        /// Feedback-data endpoint.
        feedback-data,
        /// Reserved value.
        reserved,
    }

    /// Isochronous synchronization mode.
    @since(version = 0.1.0)
    enum sync-type {
        /// No synchronization.
        no-sync,
        /// Asynchronous synchronization.
        asynchronous,
        /// Adaptive synchronization.
        adaptive,
        /// Synchronous synchronization.
        synchronous,
    }

    /// Endpoint transfer type.
    @since(version = 0.1.0)
    enum transfer-type {
        /// Control transfer endpoint.
        control,
        /// Isochronous transfer endpoint.
        isochronous,
        /// Bulk transfer endpoint.
        bulk,
        /// Interrupt transfer endpoint.
        interrupt,
    }

    /// USB endpoint descriptor.
    @since(version = 0.1.0)
    record endpoint-descriptor {
        /// Full endpoint address including direction bit.
        address: u8,
        /// Transfer direction.
        direction: direction,
        /// Polling interval.
        interval: u8,
        /// Maximum packet size in bytes.
        max-packet-size: u16,
        /// Endpoint number.
        number: u8,
        /// Audio-specific refresh value.
        refresh: u8,
        /// Isochronous synchronization mode.
        sync-type: sync-type,
        /// Audio-specific synchronization endpoint address.
        synch-address: u8,
        /// Transfer type.
        transfer-type: transfer-type,
        /// Isochronous usage type.
        usage-type: usage-type,
    }

    /// USB interface descriptor for one alternate setting.
    @since(version = 0.1.0)
    record interface-descriptor {
        /// Interface number.
        number: u8,
        /// Alternate setting number.
        alternate-setting: u8,
        /// USB class code.
        class-code: u8,
        /// USB subclass code.
        subclass-code: u8,
        /// USB protocol code.
        protocol: u8,
        /// Optional interface string descriptor index.
        interface-string-index: option<u8>,
        /// Endpoint descriptors in this alternate setting.
        endpoint-descriptors: list<endpoint-descriptor>,
    }

    /// USB configuration descriptor.
    @since(version = 0.1.0)
    record configuration-descriptor {
        /// Maximum bus power in milliamps.
        max-power: u16,
        /// Configuration value.
        number: u8,
        /// Interface descriptors for all alternate settings.
        interfaces: list<interface-descriptor>,
    }

    /// USB device descriptor.
    @since(version = 0.1.0)
    record device-descriptor {
        /// Device class code.
        device-class: u8,
        /// Device protocol code.
        device-protocol: u8,
        /// Device subclass code.
        device-subclass: u8,
        /// Device release version.
        device-version: version,
        /// Product ID.
        product-id: u16,
        /// USB spec version.
        usb-version: version,
        /// Vendor ID.
        vendor-id: u16,
        /// Endpoint 0 max packet size.
        max-packet-size: u8,
        /// Optional manufacturer string descriptor index.
        manufacturer-string-index: option<u8>,
        /// Optional product string descriptor index.
        product-string-index: option<u8>,
        /// Optional serial number string descriptor index.
        serial-number-string-index: option<u8>,
        /// Number of configurations.
        num-configurations: u8,
    }

    /// Openable USB device metadata filtered by policy.
    @since(version = 0.1.0)
    record openable-device {
        /// Canonical usbfs path, for example `/dev/bus/usb/001/002`.
        path: string,
        /// USB bus number.
        bus: u8,
        /// Device address on the bus.
        address: u8,
        /// Vendor ID.
        vendor-id: u16,
        /// Product ID.
        product-id: u16,
    }

    /// Device connection event.
    @since(version = 0.1.0)
    variant device-connection-event {
        /// No event within the requested timeout.
        pending,
        /// A policy-allowed device was connected.
        connected(openable-device),
        /// A policy-allowed device was disconnected.
        disconnected(openable-device),
    }
}

/// Claimed interface operations.
@since(version = 0.1.0)
interface usb-interface {
    @since(version = 0.1.0)
    use types.{control-setup, usb-error};
    @since(version = 0.2.0)
    use types.{bulk-read-stats};

    /// Claimed USB interface resource.
    @since(version = 0.1.0)
    resource claimed-interface {
        /// Return the claimed interface number.
        @since(version = 0.1.0)
        number: func() -> u8;

        /// Return the current alternate setting.
        @since(version = 0.1.0)
        alternate-setting: func() -> result<u8, usb-error>;

        /// Select an alternate setting for this interface.
        @since(version = 0.1.0)
        set-alternate-setting: func(setting: u8) -> result<_, usb-error>;

        /// Execute one control IN transfer.
        @since(version = 0.1.0)
        control-in: func(setup: control-setup, length: u32, timeout-ms: u32) -> result<list<u8>, usb-error>;

        /// Execute one control OUT transfer.
        @since(version = 0.1.0)
        control-out: func(setup: control-setup, data: list<u8>, timeout-ms: u32) -> result<_, usb-error>;

        /// Read one chunk from a per-endpoint bulk ring buffer.
        @since(version = 0.2.0)
        bulk-read: func(endpoint: u8, timeout-ms: u32) -> result<list<u8>, usb-error>;

        /// Return bulk ring buffer statistics for one endpoint.
        @since(version = 0.2.0)
        bulk-read-stats: func(endpoint: u8) -> result<bulk-read-stats, usb-error>;

        /// Execute one bulk OUT transfer.
        @since(version = 0.1.0)
        bulk-out: func(endpoint: u8, data: list<u8>, timeout-ms: u32) -> result<_, usb-error>;

        /// Execute one interrupt IN transfer.
        @since(version = 0.1.0)
        interrupt-in: func(endpoint: u8, length: u32, timeout-ms: u32) -> result<list<u8>, usb-error>;

        /// Execute one interrupt OUT transfer.
        @since(version = 0.1.0)
        interrupt-out: func(endpoint: u8, data: list<u8>, timeout-ms: u32) -> result<_, usb-error>;

        /// Execute one isochronous IN transfer and return each packet's actual payload bytes concatenated in packet order.
        @since(version = 0.1.0)
        isochronous-in: func(endpoint: u8, length: u32, packets: u16, timeout-ms: u32) -> result<list<u8>, usb-error>;

        /// Execute one isochronous OUT transfer.
        @since(version = 0.1.0)
        isochronous-out: func(endpoint: u8, data: list<u8>, packets: u16, timeout-ms: u32) -> result<u32, usb-error>;
    }
}

/// Device-level operations.
@since(version = 0.1.0)
interface device {
    @since(version = 0.1.0)
    use types.{configuration-descriptor, device-descriptor, usb-error};
    @since(version = 0.1.0)
    use usb-interface.{claimed-interface};

    /// Opened USB device resource.
    @since(version = 0.1.0)
    resource device {
        /// Return the normalized path used to open this device.
        @since(version = 0.1.0)
        path: func() -> string;

        /// Return the device descriptor.
        @since(version = 0.1.0)
        device-descriptor: func() -> result<device-descriptor, usb-error>;

        /// Return all configuration descriptors.
        @since(version = 0.1.0)
        configurations: func() -> result<list<configuration-descriptor>, usb-error>;

        /// Reset the device.
        @since(version = 0.1.0)
        reset: func() -> result<_, usb-error>;

        /// Return the active configuration value.
        @since(version = 0.1.0)
        active-configuration: func() -> result<u8, usb-error>;

        /// Select a configuration by `bConfigurationValue`.
        @since(version = 0.1.0)
        select-configuration: func(configuration: u8) -> result<_, usb-error>;

        /// Claim an interface, detaching kernel drivers when supported.
        @since(version = 0.1.0)
        claim-interface: func(number: u8) -> result<claimed-interface, usb-error>;

        /// Release a previously claimed interface.
        @since(version = 0.1.0)
        release-interface: func(number: u8) -> result<_, usb-error>;
    }
}

/// Provider entry points for USB resources.
@since(version = 0.1.0)
interface provider {
    @since(version = 0.1.0)
    use types.{device-connection-event, limits, openable-device, usb-error};
    @since(version = 0.1.0)
    use device.{device};

    /// Return the policy-allowed device paths that can be passed to `open-device`.
    @since(version = 0.1.0)
    list-openable-paths: func() -> list<string>;

    /// Return policy-allowed currently connected devices.
    @since(version = 0.1.0)
    list-openable-devices: func() -> result<list<openable-device>, usb-error>;

    /// Poll one device connection event, returning `pending` on timeout.
    @since(version = 0.1.0)
    poll-device-event: func(timeout-ms: u32) -> result<device-connection-event, usb-error>;

    /// Return effective runtime limits applied by this plugin.
    @since(version = 0.1.0)
    get-limits: func() -> limits;

    /// Open a USB device by absolute path.
    @since(version = 0.1.0)
    open-device: func(path: string) -> result<device, usb-error>;
}

/// Host world for USB native plugin imports.
@since(version = 0.1.0)
world host {
    import types;
    import usb-interface;
    import device;
    import provider;
}
