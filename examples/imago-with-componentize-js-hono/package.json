{
  "name": "imago-with-componentize-js-hono",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ts": "rolldown -c rolldown.config.mjs",
    "build:component": "jco componentize -w wit -o dist/component.wasm dist/component.js",
    "build": "pnpm run build:ts && pnpm run build:component"
  },
  "dependencies": {
    "@bytecodealliance/jco-std": "0.1.3",
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@bytecodealliance/componentize-js": "0.18.5",
    "@bytecodealliance/jco": "1.17.0",
    "rolldown": "1.0.0-rc.9",
    "typescript": "5.9.3"
  }
}
